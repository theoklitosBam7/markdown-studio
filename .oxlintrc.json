{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["eslint", "typescript", "unicorn", "oxc", "vue", "vitest"],
  "env": {
    "browser": true
  },
  "categories": {
    "correctness": "error"
  },
  "rules": {
    "vitest/require-mock-type-parameters": "off"
  },
  "overrides": [
    {
      "files": ["cypress/**/*"],
      "rules": {
        "vitest/valid-expect": "off"
      }
    }
  ]
}
