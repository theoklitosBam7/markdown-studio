{
  "name": "markdown-studio-monorepo",
  "version": "0.0.0",
  "private": true,
  "homepage": "https://github.com/theoklitosBam7/markdown-studio#readme",
  "bugs": {
    "url": "https://github.com/theoklitosBam7/markdown-studio/issues"
  },
  "author": {
    "name": "Theoklitos Bampouris",
    "email": "th.bampouris@gmail.com",
    "url": "https://github.com/theoklitosBam7"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/theoklitosBam7/markdown-studio"
  },
  "type": "module",
  "scripts": {
    "changeset": "changeset",
    "changeset:pre:enter": "changeset pre enter next",
    "changeset:pre:exit": "changeset pre exit",
    "changeset:status": "changeset status",
    "changeset:validate-scopes": "node ./scripts/validate-changeset-scopes.mjs",
    "changeset:version": "changeset version",
    "dev": "pnpm --filter @markdown-studio/web dev",
    "build": "pnpm type-check && run-p build:web build:desktop build:landing build:cli",
    "build:web": "pnpm --filter @markdown-studio/web build",
    "build:landing": "pnpm --filter @markdown-studio/landing build",
    "build:cli": "pnpm --filter markdown-studio build",
    "build:npm": "pnpm build:web && node ./scripts/stage-cli-package.mjs && pnpm --filter markdown-studio build",
    "build:desktop": "pnpm --filter @markdown-studio/desktop build",
    "dev:desktop": "pnpm --filter @markdown-studio/desktop dev",
    "dist:mac": "pnpm --filter @markdown-studio/desktop dist:mac",
    "preview": "pnpm --filter @markdown-studio/web preview",
    "preview:desktop": "pnpm --filter @markdown-studio/desktop preview",
    "test:unit": "pnpm -r test",
    "test:scripts": "vitest run scripts/",
    "prepare": "cypress install && simple-git-hooks",
    "generate-pwa-assets": "pwa-assets-generator",
    "generate-desktop-icons": "node scripts/generate-desktop-icons.mjs",
    "test:e2e": "VITE_DISABLE_PWA=true pnpm build:web && start-server-and-test 'pnpm --filter @markdown-studio/web exec vite preview --port 4175' http://localhost:4175 'cypress run --e2e --config baseUrl=http://localhost:4175'",
    "test:e2e:dev": "start-server-and-test 'VITE_DISABLE_PWA=true pnpm --filter @markdown-studio/web dev -- --port 4175' http://localhost:4175 'cypress open --e2e --config baseUrl=http://localhost:4175'",
    "type-check": "vue-tsc --build",
    "lint": "run-s lint:*",
    "lint:oxlint": "oxlint . --fix",
    "lint:eslint": "eslint . --fix --cache",
    "pack:npm": "pnpm build:npm && pnpm --filter markdown-studio pack:check",
    "format": "oxfmt",
    "format:check": "oxfmt --check"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@commitlint/cli": "^21.1.0",
    "@commitlint/config-conventional": "^21.1.0",
    "@tsconfig/node24": "^24.0.4",
    "@types/node": "catalog:",
    "@types/semver": "^7.7.1",
    "@vite-pwa/assets-generator": "^1.0.2",
    "@vitejs/plugin-vue": "catalog:",
    "@vitest/eslint-plugin": "^1.6.20",
    "@vue/eslint-config-typescript": "^14.9.0",
    "@vue/tsconfig": "^0.9.1",
    "cypress": "^15.18.0",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-boundaries": "^6.0.2",
    "eslint-plugin-cypress": "^6.4.1",
    "eslint-plugin-oxlint": "~1.63.0",
    "eslint-plugin-perfectionist": "^5.9.1",
    "eslint-plugin-vue": "~10.9.2",
    "jiti": "^2.7.0",
    "nano-staged": "^1.0.2",
    "npm-run-all2": "^8.0.4",
    "oxfmt": "^0.48.0",
    "oxlint": "~1.63.0",
    "png-to-ico": "^3.0.1",
    "semver": "^7.8.5",
    "sharp": "^0.34.5",
    "simple-git-hooks": "^2.13.1",
    "start-server-and-test": "^3.0.11",
    "typescript": "catalog:",
    "vitest": "catalog:",
    "vue-tsc": "catalog:"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm exec nano-staged",
    "commit-msg": "pnpm exec commitlint --edit $1"
  },
  "nano-staged": {
    "*.{mjs,js,ts,vue,css,json,md}": "pnpm run format",
    "*.{mjs,js,ts,vue}": [
      "oxlint --fix",
      "eslint --fix --cache"
    ]
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "packageManager": "pnpm@11.9.0+sha512.bd682d5d03fe525ef7c9fd6780c6884d1e756ac4c9c9fe00c538782824310dcf90e3ddc4f53835f06dfaebd5085e41855e0bcbb3b60de2ac5bbab89e5036f03b"
}
